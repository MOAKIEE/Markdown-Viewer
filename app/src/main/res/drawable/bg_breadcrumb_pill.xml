<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#24007AFF" />
            <stroke android:width="1dp" android:color="#40007AFF" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#1A007AFF" />
            <stroke android:width="1dp" android:color="#30007AFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#128E8E93" />
            <stroke android:width="1dp" android:color="#188E8E93" />
        </shape>
    </item>
</selector>

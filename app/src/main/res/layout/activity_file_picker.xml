<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background layer with decorative circles -->
    <FrameLayout
        android:id="@+id/background_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ios_background">

        <View
            android:layout_width="340dp"
            android:layout_height="340dp"
            android:layout_gravity="top|start"
            android:layout_marginTop="-80dp"
            android:layout_marginStart="-100dp"
            android:background="@drawable/blur_circle_blue"
            android:alpha="0.5" />

        <View
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="60dp"
            android:layout_marginEnd="-80dp"
            android:background="@drawable/blur_circle_purple"
            android:alpha="0.45" />

        <View
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_gravity="bottom|start"
            android:layout_marginBottom="-60dp"
            android:layout_marginStart="-60dp"
            android:background="@drawable/blur_circle_pink"
            android:alpha="0.4" />
    </FrameLayout>

    <!-- Blur overlay -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/blur_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:blurOverlayColor="#66FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:fitsSystemWindows="true">

            <!-- Glass Toolbar -->
            <LinearLayout
                android:id="@+id/toolbar_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_toolbar"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:paddingHorizontal="16dp"
                android:elevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/btn_back"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_back"
                        app:tint="@color/ios_text_primary"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tv_path"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/file_picker_title"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/ios_text_primary"
                        android:layout_marginHorizontal="12dp"
                        android:maxLines="1"
                        android:ellipsize="middle" />

                    <ImageView
                        android:id="@+id/btn_close"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_close"
                        app:tint="@color/ios_text_primary"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Breadcrumbs navigation -->
            <HorizontalScrollView
                android:id="@+id/scroll_breadcrumbs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#12FFFFFF"
                android:scrollbars="none"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:elevation="1dp"
                android:visibility="gone">
                <LinearLayout
                    android:id="@+id/layout_breadcrumbs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />
            </HorizontalScrollView>

            <!-- File List -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/ios_text_secondary"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/empty_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_folder_mini"
                        android:alpha="0.3"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/file_picker_empty"
                        android:textSize="16sp"
                        android:textColor="@color/ios_text_secondary" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"
                    android:clipToPadding="false"
                    android:layoutAnimation="@anim/layout_animation_fall_down" />
            </FrameLayout>
        </LinearLayout>
    </eightbitlab.com.blurview.BlurView>
</FrameLayout>

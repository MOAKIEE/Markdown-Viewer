<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ios_background">

    <!-- Glass Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/glass_toolbar"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:tint="@color/ios_text_primary"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="文档"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ios_text_primary"
                android:layout_marginHorizontal="12dp"
                android:maxLines="1"
                android:ellipsize="middle" />
            <ImageView
                android:id="@+id/btn_toc"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_toc"
                android:tint="@color/ios_text_primary"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />
            <ImageView
                android:id="@+id/btn_search"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_search"
                android:tint="@color/ios_text_primary"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Search bar (initially hidden) -->
    <LinearLayout
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@drawable/glass_toolbar"
        android:visibility="gone"
        android:elevation="4dp">

        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/search_field_bg"
            android:hint="搜索..."
            android:textSize="15sp"
            android:textColor="@color/ios_text_primary"
            android:textColorHint="@color/ios_text_secondary"
            android:paddingHorizontal="12dp"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1" />

        <TextView
            android:id="@+id/tv_search_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:textSize="14sp"
            android:textColor="@color/ios_text_secondary" />

        <ImageView
            android:id="@+id/btn_search_prev"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_up"
            android:tint="@color/ios_text_primary"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_search_next"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_down"
            android:tint="@color/ios_text_primary"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_search_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:tint="@color/ios_text_primary"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Content -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:clipToPadding="false">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/ios_card_bg"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/markdown_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.3"
                android:textColor="@color/ios_text_primary"
                android:textIsSelectable="true" />

        </androidx.cardview.widget.CardView>
    </ScrollView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/ios_card_bg"
    android:padding="20dp">

    <!-- BottomSheet drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@color/drag_handle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reader_config_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/ios_text_primary"
        android:layout_marginBottom="24dp" />

    <!-- Font Size Setting Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reader_font_size_label"
            android:textSize="16sp"
            android:textColor="@color/ios_text_primary" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- A- button -->
            <FrameLayout
                android:id="@+id/btn_size_decrease"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/search_field_bg"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/reader_font_size_decrease"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ios_text_primary"
                    android:gravity="center" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_current_size"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:text="16 sp"
                android:textSize="16sp"
                android:textColor="@color/ios_text_primary"
                android:gravity="center"
                android:layout_marginHorizontal="12dp" />

            <!-- A+ button -->
            <FrameLayout
                android:id="@+id/btn_size_increase"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/search_field_bg"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/reader_font_size_increase"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/ios_text_primary"
                    android:gravity="center" />
            </FrameLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_line"
        android:layout_marginVertical="16dp" />

    <!-- Line Spacing Setting Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reader_line_spacing_label"
            android:textSize="16sp"
            android:textColor="@color/ios_text_primary" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- 1.2x button -->
            <FrameLayout
                android:id="@+id/btn_spacing_12"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:background="@drawable/search_field_bg"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="1.2"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/ios_text_primary"
                    android:gravity="center" />
            </FrameLayout>

            <!-- 1.4x button -->
            <FrameLayout
                android:id="@+id/btn_spacing_14"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:background="@drawable/search_field_bg"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="1.4"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/ios_text_primary"
                    android:gravity="center" />
            </FrameLayout>

            <!-- 1.6x button -->
            <FrameLayout
                android:id="@+id/btn_spacing_16"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:background="@drawable/search_field_bg"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="1.6"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/ios_text_primary"
                    android:gravity="center" />
            </FrameLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_line"
        android:layout_marginVertical="16dp" />

    <!-- Theme Setting Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reader_theme_label"
            android:textSize="16sp"
            android:textColor="@color/ios_text_primary"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:layout_marginHorizontal="8dp">

            <!-- Classic theme circle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <FrameLayout
                    android:id="@+id/theme_classic"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/search_field_bg"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/theme_classic_circle" />
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_classic"
                    android:textSize="12sp"
                    android:textColor="@color/ios_text_secondary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Sepia theme circle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <FrameLayout
                    android:id="@+id/theme_sepia"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/search_field_bg"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/theme_sepia_bg" />
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_sepia"
                    android:textSize="12sp"
                    android:textColor="@color/ios_text_secondary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Green theme circle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <FrameLayout
                    android:id="@+id/theme_green"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/search_field_bg"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/theme_green_bg" />
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_green"
                    android:textSize="12sp"
                    android:textColor="@color/ios_text_secondary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Space theme circle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <FrameLayout
                    android:id="@+id/theme_space"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/search_field_bg"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/theme_space_bg" />
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_space"
                    android:textSize="12sp"
                    android:textColor="@color/ios_text_secondary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>

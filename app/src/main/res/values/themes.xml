<resources>
    <!-- 应用主主题：用于所有 Activity（除启动画面外） -->
    <style name="Theme.MarkdownViewer" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/ios_blue</item>
        <item name="colorPrimaryVariant">@color/ios_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- 启动画面主题：继承自 SplashScreen，用于 MainActivity -->
    <style name="Theme.MarkdownViewer.Starting" parent="Theme.SplashScreen">
        <!-- 窗口背景 -->
        <item name="windowSplashScreenBackground">@color/ios_background</item>
        <!-- 启动图标（使用应用图标） -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_app_logo</item>
        <!-- 图标背景色 -->
        <item name="windowSplashScreenIconBackgroundColor">@color/ios_background</item>
        <!-- 动画时长（最大 1000ms） -->
        <item name="windowSplashScreenAnimationDuration">300</item>
        <!-- 动画结束后切换到的主题 -->
        <item name="postSplashScreenTheme">@style/Theme.MarkdownViewer</item>
    </style>
</resources>
